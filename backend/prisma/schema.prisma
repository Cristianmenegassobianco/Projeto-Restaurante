generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TableSession {
  id           String    @id @default(uuid())
  table_number Int
  qr_token     String    @unique
  status       String    @default("active")
  opened_at    DateTime  @default(now())
  closed_at    DateTime?
  orders       Order[]
}

model Category {
  id         String    @id @default(uuid())
  name       String
  sort_order Int       @default(0)
  products   Product[]
}

model Product {
  id                String      @id @default(uuid())
  category_id       String
  name              String
  description       String?
  price             Float
  image_url         String?
  additional_images String?     @default("[]")
  sizes             String?     @default("[]")
  card_message      String?     @default("Toque para ver detalhes")
  is_available      Boolean     @default(true)
  is_featured       Boolean     @default(false)
  ncm               String      @default("N/C")
  cfop              String      @default("N/C")
  regime_tributario String      @default("Substituição Tributária")
  order_items       OrderItem[]
  category          Category    @relation(fields: [category_id], references: [id])
  suggestedProducts Product[]   @relation("ProductSuggestions")
  suggestedBy       Product[]   @relation("ProductSuggestions")
}

model Order {
  id               String       @id @default(uuid())
  table_session_id String
  status           String       @default("pending")
  comanda_number   String?
  waiter_name      String?
  total_amount     Float        @default(0)
  created_at       DateTime     @default(now())
  payment_method   String?
  nfce_emitted     Boolean      @default(false)
  nfce_access_key  String?
  table_session    TableSession @relation(fields: [table_session_id], references: [id])
  items            OrderItem[]
}

model OrderItem {
  id         String  @id @default(uuid())
  order_id   String
  product_id String
  quantity   Int     @default(1)
  unit_price Float
  notes      String?
  product    Product @relation(fields: [product_id], references: [id])
  order      Order   @relation(fields: [order_id], references: [id])
}

model Banner {
  id        String  @id @default(uuid())
  title     String
  subtitle  String?
  image_url String
  badge     String?
}

model CashMovement {
  id              String      @id
  cash_session_id String
  type            String
  method          String?
  amount          Float
  description     String?
  created_at      DateTime    @default(now())
  CashSession     CashSession @relation(fields: [cash_session_id], references: [id])
}

model CashSession {
  id              String         @id
  status          String         @default("open")
  opened_at       DateTime       @default(now())
  closed_at       DateTime?
  opening_value   Float          @default(0)
  declared_cash   Float?
  declared_cards  Float?
  expected_cash   Float          @default(0)
  difference_cash Float?
  operator_name   String         @default("Operador")
  CashMovement    CashMovement[]
}
